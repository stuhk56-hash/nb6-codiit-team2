{
  "name": "codi-it-backend",
  "version": "1.0.0",
  "description": "Shopping mall application backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma --port 5555",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down -v",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "dotenv -e .env -- npm run prisma:migrate:deploy",
    "db:setup": "npm run db:up && npm run db:migrate && npm run prisma:generate",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:reset": "docker compose -f docker-compose.test.yml down -v && docker compose -f docker-compose.test.yml up -d",
    "test:db:up:local": "sh scripts/test-db-up-local.sh",
    "test:db:down:local": "sh scripts/test-db-down-local.sh",
    "seed:mock": "npm run prisma:generate && node scripts/seed-mock.js",
    "store:purge:business-info": "node scripts/purge-store-business-info.js",
    "store:purge:business-info:dry": "node scripts/purge-store-business-info.js --dry-run",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "password:migrate": "node scripts/migrate-password-hash.js",
    "password:migrate:dry": "node scripts/migrate-password-hash.js --dry-run",
    "test": "dotenv -e .env.test -- npm run prisma:migrate:deploy && dotenv -e .env.test -- jest --runInBand",
    "test:auth:e2e": "dotenv -e .env.test -- npm run prisma:migrate:deploy && dotenv -e .env.test -- jest src/modules/auth/test/auth.e2e-spec.ts --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "dotenv -e .env.test -- npm run prisma:migrate:deploy && dotenv -e .env.test -- jest --runInBand --coverage",
    "test:cart": "dotenv -e .env.test -- npm run prisma:migrate:deploy && dotenv -e .env.test -- jest src/modules/cart/tests --runInBand",
    "test:shipping": "dotenv -e .env.test -- npm run prisma:migrate:deploy && dotenv -e .env.test -- jest src/modules/orders/tests --runInBand",
    "test:payment": "dotenv -e .env.test -- npm run prisma:migrate:deploy && dotenv -e .env.test -- jest src/modules/payments/tests --runInBand",
    "coverage:open": "open coverage/lcov-report/index.html",
    "prisma": "prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.19",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/testing": "^11.1.14",
    "@prisma/client": "^6.19.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "superstruct": "^2.0.2",
    "uuid": "^13.0.0"
  }
}
